{
  "name": "@kubedoll-heavy-industries/pulumi-playit",
  "version": "0.1.1",
  "description": "Pulumi dynamic resource for PlayIt.gg tunnel management",
  "keywords": ["pulumi", "playit", "tunnel", "game-server", "infrastructure"],
  "license": "MIT",
  "author": "Kubedoll Heavy Industries",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kubedoll-Heavy-Industries/pulumi-playit.git"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p .",
    "build:watch": "tsc -p . --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepare": "pnpm run build",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@pulumi/pulumi": "^3.0.0"
  },
  "dependencies": {
    "arktype": "2.2.0"
  },
  "devDependencies": {
    "@pulumi/pulumi": "3.243.0",
    "@types/node": "22.19.19",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20.10 <21"
  },
  "packageManager": "pnpm@9.14.4"
}
